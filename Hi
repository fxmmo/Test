local function getBeastCharacter()
    for _, p in pairs(Players:GetPlayers()) do
        local stats = p:FindFirstChild("TempPlayerStatsModule")
        if stats and stats:FindFirstChild("IsBeast") and stats.IsBeast.Value == true then
            return p.Character
        end
    end
    return nil
end

