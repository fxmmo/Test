local function applyHighlight(target, name, color, fillTransparency)
  
    local h = target:FindFirstChild(name)
    
    if not h then
        h = Instance.new("Highlight")
        h.Name = name
        h.Parent = target
    end
    
    h.FillColor = color
    h.FillTransparency = highlightTransparency or 0.5
    h.OutlineColor = color
    h.Enabled = true
    
    return h
end

